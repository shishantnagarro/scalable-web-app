option_settings:
  aws:autoscaling:launchconfiguration:
    IamInstanceProfile: aws-elasticbeanstalk-ec2-role
    SecurityGroups: sg-xxxxxxxxx
  aws:autoscaling:asg:
    MinSize: 2
    MaxSize: 6
    Cooldown: 360
  aws:autoscaling:trigger:
    MeasureName: CPUUtilization
    Unit: Percent
    UpperThreshold: 70
    LowerThreshold: 20
    ScaleUpIncrement: 2
    ScaleDownIncrement: -1
    BreachDuration: 300
  aws:ec2:vpc:
    VPCId: vpc-xxxxxxxxx
    Subnets: subnet-xxxxxxxx,subnet-yyyyyyyy
    ELBSubnets: subnet-aaaaaaaa,subnet-bbbbbbbb
    ELBScheme: public
    AssociatePublicIpAddress: false
  aws:elasticbeanstalk:application:environment:
    ASPNETCORE_ENVIRONMENT: Production
    AWS__S3BucketName: your-app-bucket-name
    AWS__DynamoDBTableName: web-app-logs
    AWS__Region: us-east-1
    AWS__SecretsManagerSecretName: web-app-db-credentials
  aws:elasticbeanstalk:healthreporting:system:
    SystemType: enhanced
  aws:elbv2:loadbalancer:
    SecurityGroups: sg-yyyyyyyyy
    ManagedSecurityGroup: sg-yyyyyyyyy
