{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=scalablewebapp;Uid=root;Pwd=password;"
  },
  "AWS": {
    "Region": "us-east-1",
    "S3BucketName": "your-app-bucket-name",
    "DynamoDBTableName": "web-app-logs",
    "SecretsManagerSecretName": "web-app-db-credentials"
  }
}
